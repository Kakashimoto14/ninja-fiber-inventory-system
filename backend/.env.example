PORT=5000
MONGODB_URI=
CLIENT_URL=http://localhost:5173

# AI Assistant
AI_PROVIDER=gemini
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_PROMPT_CHARS=6000
AI_MAX_HISTORY_MESSAGES=24
AI_HISTORY_SUMMARY_THRESHOLD=36
AI_HISTORY_RECENT_MESSAGES=16
AI_SUMMARY_CACHE_TTL_MS=30000
AI_TEMPERATURE=0.4
AI_MAX_OUTPUT_TOKENS=2048

# Gemini (default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Ninja Fiber Inventory

# Ollama (optional local provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (implemented but disabled by default)
AI_ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
